!Assay
seqspec_version: 0.3.1
assay_id: {{ assay_id }}
name: 10x Multiome GEX
doi: "None"
date: "23 June 2026"
description: single-nucleus RNA sequencing using 10x Chromium Multiome ATAC + Gene Expression
modalities:
 - rna
lib_struct: {{ library_structure }}
library_protocol: {{ library_protocol }}
library_kit: {{ library_kit }}
sequence_protocol: {{ sequencing_protocol }}
sequence_kit: {{ sequencing_kit }}

sequence_spec:
- !Read
  read_id: {{ read1_id }}
  name: {{ read1_name }}
  modality: rna
  primer_id: rna-truseq_read1
  min_len: 28
  max_len: 28
  strand: pos
  files:
{% if read1_files is defined and read1_files %}
{% for f in read1_files %}
  - !File
    file_id: {{ f.file_id }}
    filename: {{ f.filename }}
    filetype: {{ f.filetype | default('fastq') }}
    filesize: {{ f.filesize }}
    url: {{ f.url }}
    urltype: {{ f.urltype }}
    md5: {{ f.md5 }}
{% endfor %}
{% endif %}
- !Read
  read_id: {{ read2_id }}
  name: {{ read2_name }}
  modality: rna
  primer_id: rna-nextera_read2
  min_len: 44
  max_len: 44
  strand: neg
  files:
{% if read2_files is defined and read2_files %}
{% for f in read2_files %}
  - !File
    file_id: {{ f.file_id }}
    filename: {{ f.filename }}
    filetype: {{ f.filetype | default('fastq') }}
    filesize: {{ f.filesize }}
    url: {{ f.url }}
    urltype: {{ f.urltype }}
    md5: {{ f.md5 }}
{% endfor %}
{% endif %}
library_spec:
- !Region
  region_id: rna
  region_type: rna
  name: rna
  sequence_type: joined
  sequence: AATGATACGGCGACCACCGAGATCTACACNNNNNNNNACACTCTTTCCCTACACGACGCTCTTCCGATCTNNNNNNNNNNNNNNNNXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXCTGTCTCTTATACACATCTCCGAGCCCACGAGACNNNNNNNNATCTCGTATGCCGTCTTCTGCTTG
  min_len: 254
  max_len: 254
  onlist: null
  regions:
  - !Region
    region_id: rna-illumina_p5
    region_type: illumina_p5
    name: Illumina P5
    sequence_type: fixed
    sequence: AATGATACGGCGACCACCGAGATCTACAC
    min_len: 29
    max_len: 29
    onlist: null
    regions: null
    parent_id: rna
  - !Region
    region_id: rna-index5
    region_type: index5
    name: i5 index
    sequence_type: random
    sequence: NNNNNNNN
    min_len: 8
    max_len: 8
    onlist: null
    regions: null
    parent_id: rna
  - !Region
    region_id: rna-truseq_read1
    region_type: truseq_read1
    name: rna-truseq_read1
    sequence_type: fixed
    sequence: ACACTCTTTCCCTACACGACGCTCTTCCGATCT
    min_len: 33
    max_len: 33
    onlist: null
    regions: null
    parent_id: rna
  - !Region
    region_id: cell_barcode
    region_type: barcode
    name: cell_barcode
    sequence_type: onlist
    sequence: NNNNNNNNNNNNNNNN
    min_len: 16
    max_len: 16
    onlist: !Onlist
      file_id: {{ cell_barcode_file_id }}
      filename: {{ cell_barcode_file_name }}
      filetype: {{ cell_barcode_file_type }}
      filesize: {{ cell_barcode_file_size }}
      url: {{ cell_barcode_file_url }}
      urltype: {{ cell_barcode_file_urltype }}
      md5: {{ cell_barcode_file_md5 }}
    regions: null
    parent_id: rna
  - !Region
    region_id: rna-umi
    region_type: umi
    name: rna-umi
    sequence_type: random
    sequence: XXXXXXXXXXXX
    min_len: 12
    max_len: 12
    onlist: null
    regions: null
    parent_id: rna
  - !Region
    region_id: cdna
    region_type: cdna
    name: cdna
    sequence_type: random
    sequence: XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
    min_len: 90
    max_len: 90
    onlist: null
    regions: null
    parent_id: rna
  - !Region
    region_id: rna-nextera_read2
    region_type: nextera_read2
    name: rna-nextera_read2
    sequence_type: fixed
    sequence: CTGTCTCTTATACACATCTCCGAGCCCACGAGAC
    min_len: 34
    max_len: 34
    onlist: null
    regions: null
    parent_id: rna
  - !Region
    region_id: rna-index7
    region_type: index7
    name: i7 index
    sequence_type: random
    sequence: NNNNNNNN
    min_len: 8
    max_len: 8
    onlist: null
    regions: null
    parent_id: rna
  - !Region
    region_id: rna-illumina_p7
    region_type: illumina_p7
    name: Illumina P7
    sequence_type: fixed
    sequence: ATCTCGTATGCCGTCTTCTGCTTG
    min_len: 24
    max_len: 24
    onlist: null
    regions: null
    parent_id: rna
