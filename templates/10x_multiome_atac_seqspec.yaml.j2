!Assay
seqspec_version: 0.3.1
assay_id: {{ assay_id }}
name: 10x Multiome ATAC
doi: "None"
date: "23 June 2026"
description: single-nucleus ATAC-seq using 10x Chromium Multiome ATAC + Gene Expression
modalities:
 - atac
lib_struct: {{ library_structure }}
library_protocol: {{ library_protocol }}
library_kit: {{ library_kit }}
sequence_protocol: {{ sequencing_protocol }}
sequence_kit: {{ sequencing_kit }}

sequence_spec:
- !Read
  read_id: {{ read1_id }}
  name: {{ read1_name }}
  modality: atac
  primer_id: atac-nextera_read1
  min_len: 30
  max_len: 30
  strand: pos
  files:
{% if read1_files is defined and read1_files %}
{% for f in read1_files %}
  - !File
    file_id: {{ f.file_id }}
    filename: {{ f.filename }}
    filetype: {{ f.filetype | default('fastq') }}
    filesize: {{ f.filesize }}
    url: {{ f.url }}
    urltype: {{ f.urltype }}
    md5: {{ f.md5 }}
{% endfor %}
{% endif %}
- !Read
  read_id: {{ read2_id }}
  name: {{ read2_name }}
  modality: atac
  primer_id: atac-nextera_read1
  min_len: 16
  max_len: 16
  strand: neg
  files:
{% if read2_files is defined and read2_files %}
{% for f in read2_files %}
  - !File
    file_id: {{ f.file_id }}
    filename: {{ f.filename }}
    filetype: {{ f.filetype | default('fastq') }}
    filesize: {{ f.filesize }}
    url: {{ f.url }}
    urltype: {{ f.urltype }}
    md5: {{ f.md5 }}
{% endfor %}
{% endif %}
- !Read
  read_id: {{ read3_id }}
  name: {{ read3_name }}
  modality: atac
  primer_id: atac-nextera_read2
  min_len: 30
  max_len: 30
  strand: neg
  files:
{% if read3_files is defined and read3_files %}
{% for f in read3_files %}
  - !File
    file_id: {{ f.file_id }}
    filename: {{ f.filename }}
    filetype: {{ f.filetype | default('fastq') }}
    filesize: {{ f.filesize }}
    url: {{ f.url }}
    urltype: {{ f.urltype }}
    md5: {{ f.md5 }}
{% endfor %}
{% endif %}
- !Read
  read_id: {{ read_i1_id }}
  name: {{ read_i1_name }}
  modality: atac
  primer_id: atac-nextera_read2
  min_len: 8
  max_len: 8
  strand: pos
  files:
{% if read_i1_files is defined and read_i1_files %}
{% for f in read_i1_files %}
  - !File
    file_id: {{ f.file_id }}
    filename: {{ f.filename }}
    filetype: {{ f.filetype | default('fastq') }}
    filesize: {{ f.filesize }}
    url: {{ f.url }}
    urltype: {{ f.urltype }}
    md5: {{ f.md5 }}
{% endfor %}
{% endif %}
library_spec:
- !Region
  region_id: atac
  region_type: atac
  name: atac
  sequence_type: joined
  sequence: AATGATACGGCGACCACCGAGATCTACACNNNNNNNNNNNNNNNNCGCGTCTGTCGTCGGCAGCGTCAGATGTGTATAAGAGACAGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXCTGTCTCTTATACACATCTCCGAGCCCACGAGACXXXXXXXXATCTCGTATGCCGTCTTCTGCTTG
  min_len: 153
  max_len: 652
  onlist: null
  regions:
  - !Region
    region_id: atac-illumina_p5
    region_type: illumina_p5
    name: Illumina P5
    sequence_type: fixed
    sequence: AATGATACGGCGACCACCGAGATCTACAC
    min_len: 29
    max_len: 29
    onlist: null
    regions: null
    parent_id: atac
  - !Region
    region_id: atac-cell_barcode
    region_type: barcode
    name: atac-cell_barcode
    sequence_type: onlist
    sequence: NNNNNNNNNNNNNNNN
    min_len: 16
    max_len: 16
    onlist: !Onlist
      file_id: {{ cell_barcode_file_id }}
      filename: {{ cell_barcode_file_name }}
      filetype: {{ cell_barcode_file_type }}
      filesize: {{ cell_barcode_file_size }}
      url: {{ cell_barcode_file_url }}
      urltype: {{ cell_barcode_file_urltype }}
      md5: {{ cell_barcode_file_md5 }}
    regions: null
    parent_id: atac
  - !Region
    region_id: atac-linker
    region_type: linker
    name: atac-linker
    sequence_type: fixed
    sequence: CGCGTCTG
    min_len: 8
    max_len: 8
    onlist: null
    regions: null
    parent_id: atac
  - !Region
    region_id: atac-nextera_read1
    region_type: nextera_read1
    name: atac-nextera_read1
    sequence_type: fixed
    sequence: TCGTCGGCAGCGTCAGATGTGTATAAGAGACAG
    min_len: 33
    max_len: 33
    onlist: null
    regions: null
    parent_id: atac
  - !Region
    region_id: gDNA
    region_type: gdna
    name: gDNA
    sequence_type: random
    sequence: 
    min_len: 1
    max_len: 500
    onlist: null
    regions: null
    parent_id: atac
  - !Region
    region_id: atac-nextera_read2
    region_type: nextera_read2
    name: atac-nextera_read2
    sequence_type: fixed
    sequence: CTGTCTCTTATACACATCTCCGAGCCCACGAGAC
    min_len: 34
    max_len: 34
    onlist: null
    regions: null
    parent_id: atac
  - !Region
    region_id: atac-sample_index_i7
    region_type: index7
    name: atac-sample_index_i7
    sequence_type: random
    sequence: XXXXXXXX
    min_len: 8
    max_len: 8
    onlist: null
    regions: null
    parent_id: atac
  - !Region
    region_id: atac-illumina_p7
    region_type: illumina_p7
    name: Illumina P7
    sequence_type: fixed
